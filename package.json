{
  "name": "m365-policy-manager",
  "productName": "M365 Security Policy Manager",
  "version": "1.2.54",
  "description": "Cross-platform Electron desktop app for M365 security policy management",
  "author": {
    "name": "Tom Austin",
    "email": "radverth@users.noreply.github.com"
  },
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite src/renderer --port 5173",
    "dev:main": "nodemon --watch src/main --exec electron .",
    "build:renderer": "vite build src/renderer --base ./ --outDir ../../dist-renderer --emptyOutDir",
    "build:win": "npm run build:renderer && electron-builder --win --publish never",
    "build:linux": "npm run build:renderer && electron-builder --linux --publish never",
    "build:mac": "npm run build:renderer && electron-builder --mac --publish never",
    "build": "npm run build:renderer && electron-builder"
  },
  "build": {
    "appId": "com.radverth.m365-security-policy-manager",
    "productName": "M365 Security Policy Manager",
    "copyright": "Copyright © 2025 AffinityIT",
    "artifactName": "m365-policy-manager-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "dist-renderer/**/*",
      "scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts/install-powershell.sh",
        "to": "scripts/install-powershell.sh"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "radverth",
        "repo": "m365-security-policy-manager",
        "releaseType": "release"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg"
        },
        {
          "target": "zip"
        }
      ],
      "icon": "build/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "axios": "^1.7.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "html-to-docx": "^1.8.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.1.2",
    "electron-builder": "^24.13.3",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "zustand": "^4.5.2"
  }
}
